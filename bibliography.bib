@article{ ISI:000413131700085,
Author = {Yan, Aiming and Ong, Chin Shen and Qiu, Diana Y. and Ophus, Colin and
   Ciston, Jim and Merino, Christian and Louie, Steven G. and Zettl, Alex},
Title = {{Dynamics of Symmetry-Breaking Stacking Boundaries in Bilayer MoS2}},
